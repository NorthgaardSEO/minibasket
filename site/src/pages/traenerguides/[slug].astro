---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CtaBox from '../../components/CtaBox.astro';
import { fmtDato } from '../../lib/site';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const alleGuides = await getCollection('guides');
const andreGuides = alleGuides
  .filter((g) => g.id !== entry.id)
  .sort((a, b) => b.data.publiceret.getTime() - a.data.publiceret.getTime())
  .slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  inLanguage: 'da',
  datePublished: d.publiceret.toISOString().slice(0, 10),
  author: { '@type': 'Organization', name: 'Mini Basket', url: 'https://minibasket.dk/' },
  publisher: { '@type': 'Organization', name: 'Mini Basket', url: 'https://minibasket.dk/' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<Base
  title={`${d.title} | Mini Basket`}
  description={d.description}
  ogType="article"
  schema={schema}
>
  <article class="prose">
    <nav class="mono" style="font-size:11px;color:var(--ink-soft);" aria-label="Brødkrumme">
      <a href="/traenerguides/">Trænerguides</a>
    </nav>
    <h1>{d.title}</h1>
    <p class="mono" style="font-size:10px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:1px;">
      Publiceret {fmtDato(d.publiceret)}
    </p>

    <Content />

    <CtaBox campaign={entry.id} />
  </article>

  {andreGuides.length > 0 && (
    <section>
      <h2>Flere trænerguides</h2>
      <div class="guide-list">
        {andreGuides.map((g) => (
          <a class="guide-card" href={`/traenerguides/${g.id}/`}>
            <span class="dato">{fmtDato(g.data.publiceret)}</span>
            <h3>{g.data.title}</h3>
            <p>{g.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</Base>
